generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String           @id @default(cuid())
  clerkUserId String           @unique @map("clerk_user_id")
  email       String?          @unique
  name        String?
  imageUrl    String?          @map("image_url")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  brands      Brand[]
  projects    ContentProject[]
  themes      Theme[]

  @@map("users")
}

model Brand {
  id          String   @id @default(cuid())
  ownerUserId String   @map("owner_user_id")
  name        String
  websiteUrl  String?  @map("website_url")
  industry    String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner    User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  memory   BrandMemory?
  projects ContentProject[]
  themes   Theme[]

  @@unique([ownerUserId, name])
  @@index([ownerUserId])
  @@map("brands")
}

model BrandMemory {
  id               String   @id @default(cuid())
  brandId          String   @unique @map("brand_id")
  voice            String?
  audience         String?
  productsServices String?  @map("products_services")
  brandRules       String?  @map("brand_rules")
  preferredCtas    String?  @map("preferred_ctas")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("brand_memories")
}

model ContentProject {
  id          String   @id @default(cuid())
  ownerUserId String   @map("owner_user_id")
  brandId     String   @map("brand_id")
  title       String
  format      String   @default("instagram-carousel")
  status      String   @default("draft")
  canvasJson  Json     @map("canvas_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  brand Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  theme Theme?

  @@index([brandId])
  @@index([ownerUserId, updatedAt])
  @@map("content_projects")
}

model Theme {
  id          String   @id @default(cuid())
  ownerUserId String   @map("owner_user_id")
  brandId     String   @map("brand_id")
  projectId   String   @unique @map("project_id")
  name        String
  palette     Json
  typography  Json
  layout      Json
  imageStyle  String   @map("image_style")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner   User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  brand   Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  project ContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([ownerUserId, updatedAt])
  @@map("themes")
}
